{
  "name": "hf-publish-mcp",
  "version": "1.0.0",
  "description": "MCP server for the fine-tuner's publish workflow on Hugging Face Hub — upload models, inspect repos, and maintain model cards.",
  "type": "module",
  "bin": {
    "hf-publish": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "mcp",
    "huggingface",
    "llm",
    "model-upload",
    "model-card",
    "fine-tuning",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeStrate/hf-publish-mcp"
  },
  "author": "CodeStrate",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@gradio/client": "^2.2.1",
    "@huggingface/hub": "^2.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "pino": "^10.3.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  }
}
